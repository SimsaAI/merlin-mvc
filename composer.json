{
  "name": "simsaai/merlin-mvc",
  "description": "A lightweight, fast PHP framework for building modern MVC web applications and CLI tools. Merlin combines the best ideas from frameworks like Phalcon, CodeIgniter, Laravel and Twig into a minimal yet powerful toolkit.",
  "type": "library",
  "repositories": [
    {
      "type": "path",
      "url": "../clarity-engine"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "simsaai/clarity-engine": "dev-main"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpdocumentor/reflection-docblock": "^6.0",
    "twig/twig": "^3.8",
    "league/plates": "^3.6",
    "illuminate/view": "^10.49"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Merlin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Merlin\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
